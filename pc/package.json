{
  "name": "cablecast",
  "productName": "CableCast",
  "version": "1.0.0",
  "description": "Screen + audio casting to Android TV over Ethernet IP or Wi-Fi",
  "main": "src/main.js",
  "author": "Victor Gitu",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "bonjour-service": "1.3.0"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "ke.co.sale.cablecast",
    "productName": "CableCast",
    "files": [
      "src/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      { "from": "resources/control-helper.ps1", "to": "control-helper.ps1" }
    ],
    "win": {
      "target": ["nsis"],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "CableCast-Setup.exe"
    }
  }
}
